# WeatherAggregator Environment Configuration

# Required for production
POSTGRES_PASSWORD=change-me-to-a-strong-password
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Optional overrides (defaults are set in docker-compose)
# DATABASE_URL=postgres://postgres:${POSTGRES_PASSWORD}@postgres:5432/weatheraggregator
# REDIS_URL=redis://redis:6379
# NODE_ENV=production

# Optional: OpenWeatherMap API key for weather map layers (clouds, temp, wind, pressure)
# Get a free key at https://openweathermap.org/api
OWM_API_KEY=

# Initial admin user (used by db:seed script)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
